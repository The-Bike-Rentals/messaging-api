# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/message-api

# Session secret (change in production)
SESSION_SECRET=change-this-secret-in-production

# API Key for X-API-Key protected endpoints
API_KEY=change-this-api-key

# Admin credentials (run npm run init-admin to set)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# WhatsApp
WA_MAX_RECONNECT_RETRIES=5
WA_RECONNECT_INTERVAL_MS=5000

# Email defaults (can also be set via Admin UI)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# SMS defaults (can also be set via Admin UI)
# Provider: twilio | vonage | generic_http
SMS_PROVIDER=generic_http
SMS_API_URL=
SMS_API_USERNAME=
SMS_API_PASSWORD=
SMS_API_KEY=
SMS_FROM=
